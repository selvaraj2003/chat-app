# ──────────────────────────────────────────────
#  Application
# ──────────────────────────────────────────────
APP_NAME=DevOps AI Chat Assistant
ENVIRONMENT=development          # development | production

# ──────────────────────────────────────────────
#  Security / JWT
# ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ──────────────────────────────────────────────
#  Database  (MySQL)
# ──────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devops_chat

# ──────────────────────────────────────────────
#  Cloud AI  (Ollama-compatible REST API)
# ──────────────────────────────────────────────
CLOUD_API_BASE_URL=https://your-cloud-ollama-host
CLOUD_API_KEY=your-cloud-api-key
CLOUD_MODEL=gpt-oss:120b # Size - 65GB & Context Windows - 128K
CLOUD_TIMEOUT=300               # seconds

# ──────────────────────────────────────────────
#  CORS
# ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,api-url.com,ui-url.com

# ──────────────────────────────────────────────
#  Logging
# ──────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
